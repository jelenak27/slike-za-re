        stop:0 #e08800, stop:1 #f5c000);
    border-radius: 2px;
}

QSpinBox {
    border: 1px solid #aaa;
    border-radius: 3px;
    padding: 2px 4px;
    background: white;
    font-size: 12px;
}</string>
