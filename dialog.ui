    font-size: 12px;
    color: #222;
}

QPushButton:hover {
    background: #d0e0f0;
    border-color: #5a80b0;
}

QPushButton:pressed {
    background: #b8cce0;
}

QProgressBar {
    border: 1px solid #aaa;
    border-radius: 3px;
    text-align: right;
    padding-right: 4px;
    background: #e8e8e8;
    font-size: 11px;
    color: #333;
}

QProgressBar::chunk {
